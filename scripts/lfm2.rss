fn weight(name: string) -> int {
    torch::weights::get(name)
}
fn linear(input: int, weight_handle: int) -> int {
    torch::nn::linear(input, weight_handle, 0)
}
fn rms_norm(input: int, weight_handle: int) -> int {
    torch::nn::rms_norm(input, weight_handle, 0.00001)
}
fn add_rms_norm(input: int, residual: int, weight_handle: int) -> int {
    torch::nn::add_rms_norm(input, residual, weight_handle, 0.00001)
}
fn rotate_half(input: int) -> int {
    let head_dim: int = torch::tensor::size(input, -1);
    let half = head_dim / 2;
    let first: int = torch::tensor::narrow(input, -1, 0, half);
    let second: int = torch::tensor::narrow(input, -1, half, half);
    let neg_second: int = torch::tensor::neg(second);
    torch::tensor::cat2(neg_second, first, -1)
}
fn apply_rope(input: int, cos: int, sin: int) -> int {
    torch::nn::apply_rope(input, cos, sin)
}
fn apply_rope_pair(query: int, key: int, cos: int, sin: int) -> int {
    torch::nn::apply_rope_pair(query, key, cos, sin)
}
fn repeat_kv(input: int) -> int {
    torch::tensor::repeat_interleave(input, 2, 1)
}
