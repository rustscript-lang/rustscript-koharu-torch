fn attention_mixer(
    input: int,
    prefix: string,
    layer: int,
    incremental: bool,
    cos: int,
    sin: int
) -> int {
    let batch: int = torch::tensor::size(input, 0);
    let seq_len: int = torch::tensor::size(input, 1);
    let hidden = rms_norm(input, operator_norm_weights.copy()[layer]);
    let qkv_linear = linear(hidden, qkv_weights.copy()[layer]);
    let q_linear: int = torch::tensor::narrow(qkv_linear, -1, 0, 1024);
    let k_linear: int = torch::tensor::narrow(qkv_linear, -1, 1024, 512);
    let v_linear: int = torch::tensor::narrow(qkv_linear, -1, 1536, 512);
    let q_view: int = torch::tensor::view4(q_linear, batch, seq_len, 16, 64);
    let k_view: int = torch::tensor::view4(k_linear, batch, seq_len, 8, 64);
    let v_view: int = torch::tensor::view4(v_linear, batch, seq_len, 8, 64);
    let q_norm = rms_norm(q_view, q_norm_weights.copy()[layer]);
    let k_norm = rms_norm(k_view, k_norm_weights.copy()[layer]);
    let q_heads: int = torch::tensor::transpose(q_norm, 1, 2);
    let k_heads: int = torch::tensor::transpose(k_norm, 1, 2);
    let v_heads: int = torch::tensor::transpose(v_view, 1, 2);
    let qk_rot = apply_rope_pair(q_heads, k_heads, cos, sin);
    let q_rot: int = torch::pair::local(qk_rot);
    let k_rot: int = torch::pair::global(qk_rot);
    let k_cache_name = prefix + ".self_attn.k_cache";
    let v_cache_name = prefix + ".self_attn.v_cache";
    let mut k_all = k_rot;
    let mut v_all = v_heads;
    if incremental {
        let old_k: int = torch::cache::get(k_cache_name);
        let old_v: int = torch::cache::get(v_cache_name);
        let k_cat: int = torch::tensor::cat2(old_k, k_rot, 2);
        let v_cat: int = torch::tensor::cat2(old_v, v_heads, 2);
        k_all = k_cat;
        v_all = v_cat;
    }
    torch::cache::set(k_cache_name, k_all);
    torch::cache::set(v_cache_name, v_all);
    let k_full = repeat_kv(k_all);
    let v_full = repeat_kv(v_all);
    let attended: int = torch::nn::scaled_dot_product_attention(
        q_rot,
        k_full,
        v_full,
        !incremental
    );
    let transposed: int = torch::tensor::transpose(attended, 1, 2);
    let contiguous: int = torch::tensor::contiguous(transposed);
    let merged: int = torch::tensor::view3(
        contiguous,
        batch,
        seq_len,
        1024
    );
    linear(merged, attention_out_weights.copy()[layer])
}
fn conv_mixer(input: int, prefix: string, layer: int, incremental: bool) -> int {
    let seq_len: int = torch::tensor::size(input, 1);
    let hidden = rms_norm(input, operator_norm_weights.copy()[layer]);
    let projected: int = torch::tensor::transpose(
        linear(hidden, conv_in_weights.copy()[layer]),
        -1,
        -2
    );
    let b_part: int = torch::tensor::narrow(projected, 1, 0, 1024);
    let c_part: int = torch::tensor::narrow(projected, 1, 1024, 1024);
    let x_part: int = torch::tensor::narrow(projected, 1, 2048, 1024);
    let bx: int = torch::tensor::mul(b_part, x_part);
    let state_name = prefix + ".conv.state";
    let conv_weight: int = conv_weights.copy()[layer];
    let conv_trimmed: int = if incremental => {
        let old_state: int = torch::cache::get(state_name);
        let step_result: int = torch::nn::conv1d_step(old_state, bx, conv_weight);
        torch::cache::set(state_name, torch::pair::global(step_result));
        torch::pair::local(step_result)
    } else => {
        let conv_full: int = torch::nn::conv1d(
            bx,
            conv_weight,
            0,
            1,
            2,
            1,
            1024
        );
        let state: int = torch::tensor::tail(bx, 2, 2);
        torch::cache::set(state_name, state);
        torch::tensor::narrow(conv_full, -1, 0, seq_len)
    };
    let mixed: int = torch::tensor::transpose(
        torch::tensor::mul(c_part, conv_trimmed),
        -1,
        -2
    );
    let mixed_contiguous: int = torch::tensor::contiguous(mixed);
    linear(mixed_contiguous, conv_out_weights.copy()[layer])
}
fn mlp(input: int, layer: int) -> int {
    let gate_up = linear(input, mlp_gate_up_weights.copy()[layer]);
    let down_weight: int = mlp_down_weights.copy()[layer];
    torch::nn::swiglu_linear(gate_up, down_weight, 0)
}
fn finish_layer(input: int, layer: int, mixed: int) -> int {
    let hidden_norm = add_rms_norm(input, mixed, ffn_norm_weights.copy()[layer]);
    let hidden: int = torch::pair::local(hidden_norm);
    let ffn_input: int = torch::pair::global(hidden_norm);
    let feed_forward = mlp(ffn_input, layer);
    torch::tensor::add(hidden, feed_forward)
}
fn conv_layer(input: int, prefix: string, layer: int, incremental: bool) -> int {
    let mixed = conv_mixer(input, prefix, layer, incremental);
    finish_layer(input, layer, mixed)
}
fn attention_layer(
    input: int,
    prefix: string,
    layer: int,
    incremental: bool,
    cos: int,
    sin: int
) -> int {
    let mixed = attention_mixer(input, prefix, layer, incremental, cos, sin);
    finish_layer(input, layer, mixed)
}
fn model(input_ids: int, position: int, incremental: bool) -> int {
    let embeddings: int = torch::nn::embedding(input_ids, embed_weight);
    let seq_len: int = torch::tensor::size(input_ids, 1);
    let cos: int = torch::tensor::rope_cos_at(seq_len, 64, 1000000.0, position);
    let sin: int = torch::tensor::rope_sin_at(seq_len, 64, 1000000.0, position);
    let mut hidden = embeddings;
    hidden = conv_layer(hidden, "model.layers.0", 0, incremental);
    hidden = conv_layer(hidden, "model.layers.1", 1, incremental);
    hidden = attention_layer(hidden, "model.layers.2", 2, incremental, cos, sin);
    hidden = conv_layer(hidden, "model.layers.3", 3, incremental);
    hidden = conv_layer(hidden, "model.layers.4", 4, incremental);
    hidden = attention_layer(hidden, "model.layers.5", 5, incremental, cos, sin);
    hidden = conv_layer(hidden, "model.layers.6", 6, incremental);
    hidden = conv_layer(hidden, "model.layers.7", 7, incremental);
    hidden = attention_layer(hidden, "model.layers.8", 8, incremental, cos, sin);
    hidden = conv_layer(hidden, "model.layers.9", 9, incremental);
    hidden = attention_layer(hidden, "model.layers.10", 10, incremental, cos, sin);
    hidden = conv_layer(hidden, "model.layers.11", 11, incremental);
    hidden = attention_layer(hidden, "model.layers.12", 12, incremental, cos, sin);
    hidden = conv_layer(hidden, "model.layers.13", 13, incremental);
    hidden = attention_layer(hidden, "model.layers.14", 14, incremental, cos, sin);
    hidden = conv_layer(hidden, "model.layers.15", 15, incremental);
    let normalized = rms_norm(hidden, embedding_norm_weight);
    let seq_len: int = torch::tensor::size(normalized, 1);
    let last_hidden: int = torch::tensor::select(normalized, 1, seq_len - 1);
    torch::nn::linear(last_hidden, lm_head_weight, 0)
}
let prompt_tokens: int = torch::tokenizer::encode_chat(system_prompt, source_text);
let prompt_len: int = torch::tensor::size(prompt_tokens, 1);
let mut tokens = prompt_tokens;
let mut step = 0;
let mut generated_tokens = 0;
let mut decode_started = false;
torch::cache::clear();
torch::runtime::start_timer();
torch::tokenizer::clear_generated_tokens();
let mut logits = model(prompt_tokens, 0, false);
torch::runtime::compact2(logits, tokens);
if ignore_eos == 0 {
    while step < max_new_tokens {
        let next_token: int = torch::tensor::argmax_int(logits, -1);
        let appended: int = torch::tokenizer::append_token(tokens, next_token);
        tokens = appended;
        generated_tokens = generated_tokens + 1;
        step = step + 1;
        if torch::tokenizer::is_eos(next_token) {
            break;
        }
        if step < max_new_tokens {
            let decode_input: int = torch::tokenizer::single_token(next_token);
            let decode_position: int = prompt_len + generated_tokens - 1;
            if !decode_started {
                torch::runtime::start_decode_timer();
                decode_started = true;
            }
            logits = model(decode_input, decode_position, true);
            torch::runtime::compact2(logits, tokens);
        }
    }
} else {
    while step < max_new_tokens {
        let next_token: int = torch::tensor::argmax_token(logits, -1);
        torch::tokenizer::push_generated_token_tensor(next_token);
        generated_tokens = generated_tokens + 1;
        step = step + 1;
        if step < max_new_tokens {
            let decode_position: int = prompt_len + generated_tokens - 1;
            if !decode_started {
                torch::runtime::start_decode_timer();
                decode_started = true;
            }
            logits = model(next_token, decode_position, true);
            torch::runtime::compact2(logits, tokens);
        }
    }
}
let output_text: string = if ignore_eos == 0 => {
    torch::tokenizer::decode_generated(tokens, prompt_len)
} else => {
    torch::tokenizer::decode_generated_tokens()
};
let decode_tokens: int = if generated_tokens > 0 => {
    generated_tokens - 1
} else => {
    0
};
torch::runtime::set_token_count(generated_tokens);
torch::runtime::set_decode_token_count(decode_tokens);
torch::runtime::set_text_output(output_text);
