use flint;

let weights_path: string = flint::runtime::arg(0);
let tokenizer_path: string = flint::runtime::arg(1);
let system_prompt: string = flint::runtime::arg(2);
let source_text: string = flint::runtime::arg(3);
let max_new_tokens: int = flint::runtime::arg_int(4);
let ignore_eos: int = flint::runtime::arg_int_or(5, 0);
let model_kind: int = flint::runtime::arg_int_or(6, 0);

flint::weights::load(weights_path);
flint::tokenizer::load(tokenizer_path);

fn is_vl_model() -> bool {
    let kind: int = flint::runtime::arg_int_or(6, 0);
    kind == 1
}

fn model_prefix() -> string {
    if is_vl_model() => {
        "model.language_model"
    } else => {
        "model"
    }
}

fn text_key(name: string) -> string {
    model_prefix() + "." + name
}

fn text_weight(name: string) -> int {
    let handle: int = flint::weights::get(text_key(name));
    handle
}

fn text_optional_weight(name: string) -> int {
    let handle: int = flint::weights::get_optional(text_key(name));
    handle
}

fn vl_weight(name: string) -> int {
    let handle: int = flint::weights::get_optional("model." + name);
    handle
}

fn linear(input: int, weight_handle: int) -> int {
    flint::nn::linear(input, weight_handle, 0)
}

fn linear_bias(input: int, weight_handle: int, bias_handle: int) -> int {
    flint::nn::linear(input, weight_handle, bias_handle)
}

fn rms_norm(input: int, weight_handle: int) -> int {
    flint::nn::rms_norm(input, weight_handle, 0.00001)
}

fn add_rms_norm(input: int, residual: int, weight_handle: int) -> int {
    flint::nn::add_rms_norm(input, residual, weight_handle, 0.00001)
}

fn layer_norm(input: int, weight_handle: int, bias_handle: int, hidden_size: int) -> int {
    flint::nn::layer_norm(input, weight_handle, bias_handle, 0.000001, hidden_size)
}

fn apply_rope_pair(query: int, key: int, cos: int, sin: int) -> int {
    flint::nn::apply_rope_pair(query, key, cos, sin)
}

fn repeat_kv(input: int) -> int {
    flint::tensor::repeat_interleave(input, 2, 1)
}

let embed_weight: int = text_weight("embed_tokens.weight");
let embedding_norm_weight: int = text_weight("embedding_norm.weight");
let lm_head_weight: int = embed_weight;

fn token_embeddings(input_ids: int) -> int {
    let weight: int = text_weight("embed_tokens.weight");
    flint::nn::embedding(input_ids, weight)
}

fn final_norm(input: int) -> int {
    let weight: int = text_weight("embedding_norm.weight");
    rms_norm(input, weight)
}

fn lm_head(input: int) -> int {
    let weight: int = text_weight("embed_tokens.weight");
    flint::nn::linear(input, weight, 0)
}

