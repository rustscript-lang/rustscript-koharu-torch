use stdlib::rss::cli as cli;
use flint;

let parser: int = flint::cli::argument_parser();
flint::cli::set_description(parser, "Generate text from a GGUF model with llama.cpp");
let model_arg: int = cli::required_option::<string>(
    parser,
    "",
    ["-m", "--model"],
    "Store",
    "GGUF model path"
);
let system_arg: int = cli::option::<string>(
    parser,
    "You are a helpful assistant.",
    ["-sys", "--system-prompt"],
    "Store",
    "System prompt"
);
let prompt_arg: int = cli::required_option::<string>(
    parser,
    "",
    ["-p", "--prompt"],
    "Store",
    "User prompt"
);
let predict_arg: int = cli::option::<int>(
    parser,
    128,
    ["-n", "--predict", "--n-predict"],
    "Store",
    "Maximum generated tokens"
);
let backend_arg: int = cli::option::<string>(
    parser,
    "auto",
    ["--backend"],
    "Store",
    "llama.cpp backend"
);
let gpu_layers_arg: int = cli::option::<int>(
    parser,
    999,
    ["-ngl", "--gpu-layers", "--n-gpu-layers"],
    "Store",
    "Layers stored in VRAM"
);
let main_gpu_arg: int = cli::option::<int>(
    parser,
    0,
    ["-mg", "--main-gpu"],
    "Store",
    "Primary GPU index"
);
let ctx_arg: int = cli::option::<int>(
    parser,
    2048,
    ["-c", "--ctx-size"],
    "Store",
    "Context size"
);
let batch_arg: int = cli::option::<int>(
    parser,
    2048,
    ["-b", "--batch-size"],
    "Store",
    "Logical batch size"
);
let ubatch_arg: int = cli::option::<int>(
    parser,
    512,
    ["-ub", "--ubatch-size"],
    "Store",
    "Physical batch size"
);
let threads_arg: int = cli::option::<int>(
    parser,
    8,
    ["-t", "--threads"],
    "Store",
    "Generation threads"
);
let threads_batch_arg: int = cli::option::<int>(
    parser,
    8,
    ["-tb", "--threads-batch"],
    "Store",
    "Batch threads"
);
let temp_arg: int = cli::option::<float>(parser, 0.7, ["--temp"], "Store", "Temperature");
let top_k_arg: int = cli::option::<int>(parser, 40, ["--top-k"], "Store", "Top-k sampling");
let top_p_arg: int = cli::option::<float>(parser, 0.95, ["--top-p"], "Store", "Top-p sampling");
let min_p_arg: int = cli::option::<float>(parser, 0.0, ["--min-p"], "Store", "Min-p sampling");
let seed_arg: int = cli::option::<int>(parser, 42, ["-s", "--seed"], "Store", "Sampling seed");
let mmap_arg: int = cli::option::<bool>(
    parser,
    true,
    ["--mmap"],
    "StoreTrue",
    "Enable memory mapping"
);
let no_mmap_arg: int = cli::option::<bool>(
    parser,
    false,
    ["--no-mmap"],
    "StoreTrue",
    "Disable memory mapping"
);
let mlock_arg: int = cli::option::<bool>(
    parser,
    false,
    ["--mlock"],
    "StoreTrue",
    "Lock model pages in memory"
);
let ignore_eos_arg: int = cli::option::<bool>(
    parser,
    false,
    ["--ignore-eos"],
    "StoreTrue",
    "Continue generation after an end-of-generation token"
);
let chat_template_arg: int = cli::option::<string>(
    parser,
    "",
    ["--chat-template"],
    "Store",
    "Override the model chat template"
);
flint::cli::parse_args(parser);

let model_path = cli::get::<string>(model_arg);
let system_prompt = cli::get::<string>(system_arg);
let user_prompt = cli::get::<string>(prompt_arg);
let max_new_tokens = cli::get::<int>(predict_arg);
let backend_name = cli::get::<string>(backend_arg);
let gpu_layers = cli::get::<int>(gpu_layers_arg);
let main_gpu = cli::get::<int>(main_gpu_arg);
let n_ctx = cli::get::<int>(ctx_arg);
let n_batch = cli::get::<int>(batch_arg);
let n_ubatch = cli::get::<int>(ubatch_arg);
let n_threads = cli::get::<int>(threads_arg);
let n_threads_batch = cli::get::<int>(threads_batch_arg);
let temperature = cli::get::<float>(temp_arg);
let top_k = cli::get::<int>(top_k_arg);
let top_p = cli::get::<float>(top_p_arg);
let min_p = cli::get::<float>(min_p_arg);
let seed = cli::get::<int>(seed_arg);
let use_mmap = cli::get::<bool>(mmap_arg) && !cli::get::<bool>(no_mmap_arg);
let use_mlock = cli::get::<bool>(mlock_arg);
let ignore_eos = cli::get::<bool>(ignore_eos_arg);
let chat_template = cli::get::<string>(chat_template_arg);

let backend: int = flint::llama::backend_init(backend_name);
let model_params: int = flint::llama::model_params_init(backend);
flint::llama::model_params_set_gpu_layers(model_params, gpu_layers);
flint::llama::model_params_set_main_gpu(model_params, main_gpu);
flint::llama::model_params_set_memory(model_params, use_mmap, use_mlock);
let model: int = flint::llama::model_load(backend, model_params, model_path);

let template: int = flint::llama::chat_template(model, chat_template);
let messages: int = flint::llama::chat_messages_init();
flint::llama::chat_messages_add(messages, "system", system_prompt);
flint::llama::chat_messages_add(messages, "user", user_prompt);
let prompt: string = flint::llama::apply_chat_template(model, template, messages, true);
let tokens: int = flint::llama::model_tokenize(model, prompt, true);
let prompt_len: int = flint::llama::tokens_len(tokens);

let context_params: int = flint::llama::context_params_init(backend);
flint::llama::context_params_set_sizes(context_params, n_ctx, n_batch, n_ubatch);
flint::llama::context_params_set_threads(context_params, n_threads, n_threads_batch);
let context: int = flint::llama::context_new(model, backend, context_params);
let batch: int = flint::llama::batch_init(n_ctx, 1);
flint::llama::batch_add_sequence(batch, tokens, 0, false);
flint::llama::context_decode(context, batch);

let sampler: int = flint::llama::sampler_chain_init(false);
flint::llama::sampler_add_top_k(sampler, top_k);
flint::llama::sampler_add_top_p(sampler, top_p, 1);
flint::llama::sampler_add_min_p(sampler, min_p, 1);
flint::llama::sampler_add_temp(sampler, temperature);
flint::llama::sampler_add_dist(sampler, seed);
flint::llama::sampler_chain_build(sampler);

let decoder: int = flint::llama::decoder_init();
let mut output: string = "";
let mut position: int = prompt_len;
let mut generated: int = 0;
flint::runtime::start_decode_timer();
while generated < max_new_tokens {
    let token: int = flint::llama::sampler_sample(sampler, context, -1);
    if !ignore_eos && flint::llama::model_is_eog(model, token) {
        break;
    }
    flint::llama::sampler_accept(sampler, token);
    let piece: string = flint::llama::decoder_push(decoder, model, token, false);
    output = output + piece;
    flint::llama::batch_clear(batch);
    flint::llama::batch_add(batch, token, position, 0, true);
    flint::llama::context_decode(context, batch);
    position = position + 1;
    generated = generated + 1;
}

flint::runtime::set_decode_token_count(generated);
flint::runtime::set_text_output(output);
flint::llama::decoder_free(decoder);
flint::llama::sampler_free(sampler);
flint::llama::batch_free(batch);
flint::llama::tokens_free(tokens);
flint::llama::chat_free(messages);
flint::llama::chat_free(template);
flint::llama::context_free(context);
flint::llama::model_free(model);
flint::llama::backend_free(backend);
output;
