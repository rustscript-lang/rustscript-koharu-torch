// Path helpers implemented in pure RustScript.
fn is_separator(ch: string) -> bool {
    ch == "/" || ch == "\\"
}

fn trim_trailing_separators(path: string) -> string {
    let mut end = (&path).length;
    while end > 1 && is_separator((&path)[(end - 1):end]) {
        end = end - 1;
    }
    (&path)[0:end]
}

// Replaces backslashes with forward slashes in a path.
pub fn normalize_sep(path: string) -> string {
    let mut out = "";
    for index in 0..(&path).length {
        let ch = (&path)[index:(index + 1)];
        let segment = if ch == "\\" => {
            "/"
        } else => {
            ch
        };
        out = out + segment;
    }
    out
}

// Joins two path segments with a single separator.
pub fn join(lhs: string, rhs: string) -> string {
    let left = normalize_sep(lhs);
    let right = normalize_sep(rhs);
    let out = if (&left).length == 0 => {
        right
    } else if (&right).length == 0 => {
        left
    } else => {
        let left_last = (&left)[((&left).length - 1):(&left).length];
        let right_first = (&right)[0:1];
        if is_separator(left_last) && is_separator(right_first) => {
            left +(&right)[1:(&right).length]
        } else if is_separator(left_last) || is_separator(right_first) => {
            left + right
        } else => {
            left + "/" + right
        }
    };
    out
}

// Returns the final path segment.
pub fn basename(path: string) -> string {
    let normalized = trim_trailing_separators(normalize_sep(path));
    let mut start = 0;
    let mut index = (&normalized).length - 1;
    while index > -1 {
        if (&normalized)[index:(index + 1)] == "/" {
            start = index + 1;
            break;
        }
        index = index - 1;
    }
    (&normalized)[start:(&normalized).length]
}

// Returns the parent directory portion of a path.
pub fn dirname(path: string) -> string {
    let normalized = trim_trailing_separators(normalize_sep(path));
    let mut cut = -1;
    let mut index = (&normalized).length - 1;
    while index > -1 {
        if (&normalized)[index:(index + 1)] == "/" {
            cut = index;
            break;
        }
        index = index - 1;
    }
    let out = if cut < 0 => {
        ""
    } else if cut == 0 => {
        "/"
    } else => {
        (&normalized)[0:cut]
    };
    out
}

// Returns the file extension of a path.
pub fn extname(path: string) -> string {
    let name = basename(path);
    let mut dot = -1;
    let mut index = (&name).length - 1;
    while index > -1 {
        if (&name)[index:(index + 1)] == "." {
            dot = index;
            break;
        }
        index = index - 1;
    }
    let out = if dot < 1 => {
        ""
    } else => {
        (&name)[dot:(&name).length]
    };
    out
}
